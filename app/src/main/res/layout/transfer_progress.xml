<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2C3E5F"
    tools:context=".Activity.TransferProgressActivity">

    <!-- Main Scrollable Container -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <!-- ============================================ -->
            <!-- STATUS SECTION (Connecting/Initializing) -->
            <!-- ============================================ -->
            <LinearLayout
                android:id="@+id/statusSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="visible">

                <!-- Spinner -->
                <ProgressBar
                    android:id="@+id/progressSpinner"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:indeterminate="true"
                    android:indeterminateTint="#5B9FED"/>

                <!-- Status Message -->
                <TextView
                    android:id="@+id/tvStatusMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connecting to receiver..."
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="24dp"
                    android:gravity="center"/>

            </LinearLayout>

            <!-- ============================================ -->
            <!-- FILE INFO CARD -->
            <!-- ============================================ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/fileInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <!-- File Preview Icon -->
                    <ImageView
                        android:id="@+id/ivFilePreview"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_file_large"
                        app:tint="#5B9FED"/>

                    <!-- File Details -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/tvFileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="document.pdf"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#2C3E5F"
                            android:maxLines="2"
                            android:ellipsize="end"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:id="@+id/tvFileSize"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2.5 MB"
                                android:textSize="13sp"
                                android:textColor="#8A9BAE"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" • "
                                android:textSize="13sp"
                                android:textColor="#8A9BAE"/>

                            <TextView
                                android:id="@+id/tvFileType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PDF"
                                android:textSize="13sp"
                                android:textColor="#8A9BAE"
                                android:textAllCaps="true"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ============================================ -->
            <!-- DEVICE INFO CARD -->
            <!-- ============================================ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/deviceInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#3D5170"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_phone"
                        app:tint="#FFFFFF"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tvDeviceRole"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Receiver"
                            android:textSize="12sp"
                            android:textColor="#8A9BAE"/>

                        <TextView
                            android:id="@+id/tvDeviceName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Android_456"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:layout_marginTop="2dp"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ============================================ -->
            <!-- PROGRESS SECTION -->
            <!-- ============================================ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/progressSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Progress Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Transfer Progress"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#2C3E5F"/>

                    <!-- Progress Bar Container -->
                    <FrameLayout
                        android:id="@+id/progressBarContainer"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/progress_bg">

                        <View
                            android:id="@+id/progressBar"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/progress_filled"/>

                    </FrameLayout>

                    <!-- Progress Percentage and Speed -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:id="@+id/tvProgressPercent"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0%"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#5B9FED"/>

                        <TextView
                            android:id="@+id/tvTransferSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 MB/s"
                            android:textSize="14sp"
                            android:textColor="#8A9BAE"/>

                    </LinearLayout>

                    <!-- Data Transferred -->
                    <TextView
                        android:id="@+id/tvProgressDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 MB / 2.5 MB"
                        android:textSize="13sp"
                        android:textColor="#8A9BAE"
                        android:layout_marginTop="4dp"/>

                    <!-- Time Remaining -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:background="#F5F5F5"
                        android:padding="12dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_time"
                            app:tint="#8A9BAE"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Time remaining: "
                            android:textSize="12sp"
                            android:textColor="#8A9BAE"
                            android:layout_marginStart="8dp"/>

                        <TextView
                            android:id="@+id/tvTimeRemaining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calculating..."
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#2C3E5F"/>

                    </LinearLayout>

                    <!-- Cancel Button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center">

                        <androidx.cardview.widget.CardView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardCornerRadius="20dp"
                            app:cardBackgroundColor="#FF5252"
                            app:cardElevation="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?android:attr/selectableItemBackground">

                            <ImageView
                                android:id="@+id/btnCancelTransfer"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_close"
                                app:tint="#FFFFFF"/>

                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cancel Transfer"
                            android:textSize="14sp"
                            android:textColor="#8A9BAE"
                            android:layout_marginStart="12dp"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ============================================ -->
            <!-- COMPLETION SECTION -->
            <!-- ============================================ -->
            <LinearLayout
                android:id="@+id/completionSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginTop="24dp">

                <!-- Completion Icon -->
                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        app:cardCornerRadius="60dp"
                        app:cardBackgroundColor="#4CAF50"
                        app:cardElevation="8dp">

                        <ImageView
                            android:id="@+id/ivCompletionIcon"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_check"
                            app:tint="#FFFFFF"/>

                    </androidx.cardview.widget.CardView>

                </FrameLayout>

                <!-- Completion Message -->
                <TextView
                    android:id="@+id/tvCompletionMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transfer Complete!"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="24dp"
                    android:gravity="center"/>

                <!-- Completion Details -->
                <TextView
                    android:id="@+id/tvCompletionDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="File sent successfully"
                    android:textSize="14sp"
                    android:textColor="#8A9BAE"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"/>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="32dp"
                    android:gravity="center">

                    <!-- View File Button (for receiver only) -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnViewFile"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:visibility="gone"
                        app:cardCornerRadius="25dp"
                        app:cardBackgroundColor="#3D5170"
                        app:cardElevation="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="View File"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp"/>

                    </androidx.cardview.widget.CardView>

                    <!-- Done Button -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnDone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="25dp"
                        app:cardBackgroundColor="#4CAF50"
                        app:cardElevation="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Done"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp"/>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
