<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2C3E5F"
    tools:context=".Activity.TransferProgressActivity">

    <!-- Main Content Container -->
    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Animated Transfer Icon -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardTransferIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="60dp"
            app:cardBackgroundColor="#3D5170"
            app:cardElevation="8dp">

            <androidx.cardview.widget.CardView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                app:cardCornerRadius="45dp"
                app:cardBackgroundColor="#5B9FED"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivTransferIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_transfer"
                    app:tint="#FFFFFF"/>

            </androidx.cardview.widget.CardView>

        </androidx.cardview.widget.CardView>

        <!-- Transfer Status Text (Changes based on mode) -->
        <TextView
            android:id="@+id/tvTransferStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sending File"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="40dp"/>

        <!-- Progress Bar Container -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- File Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_file"
                        app:tint="#5B9FED"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tvFileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="document.pdf"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#2C3E5F"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                        <TextView
                            android:id="@+id/tvFileSize"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2.5 MB"
                            android:textSize="13sp"
                            android:textColor="#8A9BAE"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Progress Bar -->
                <FrameLayout
                    android:id="@+id/progressBarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/progress_bg">

                    <View
                        android:id="@+id/progressBar"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/progress_filled"/>

                </FrameLayout>

                <!-- Progress Percentage -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/tvProgressPercent"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0%"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#5B9FED"/>

                    <TextView
                        android:id="@+id/tvTransferSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 MB/s"
                        android:textSize="13sp"
                        android:textColor="#8A9BAE"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Transfer Details (Changes based on mode) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvTransferDirection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sending to"
                android:textSize="14sp"
                android:textColor="#8A9BAE"/>

            <TextView
                android:id="@+id/tvDeviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Android_456"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Cancel Button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#3D5170"
            app:cardElevation="4dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel Transfer"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"/>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Success/Complete State (Initially Hidden) -->
    <LinearLayout
        android:id="@+id/successContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Success Icon -->
        <androidx.cardview.widget.CardView
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="60dp"
            app:cardBackgroundColor="#4CAF50"
            app:cardElevation="8dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                app:tint="#FFFFFF"/>

        </androidx.cardview.widget.CardView>

        <!-- Success Text (Changes based on mode) -->
        <TextView
            android:id="@+id/tvSuccessMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="File Sent Successfully"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:layout_marginTop="32dp"/>

        <!-- Completed Progress Bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/progress_complete"/>

        <!-- File Details -->
        <TextView
            android:id="@+id/tvCompletedFileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="document.pdf"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/tvCompletedSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2.5 MB transferred"
            android:textSize="14sp"
            android:textColor="#8A9BAE"
            android:layout_marginTop="8dp"/>

        <!-- Done Button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnDone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#4CAF50"
            app:cardElevation="6dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Done"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"/>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>